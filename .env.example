# ============================================
# Investment Masters Roundtable — Configuration
# ============================================
# Copy this file to .env and fill in your values

# LLM Configuration (supports OpenAI / DeepSeek / Qwen / any OpenAI-compatible API)
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o

# Data Source Configuration
DEFAULT_PERIOD=2y
DEFAULT_INTERVAL=1d
FMP_API_KEY=  # Optional: financialmodelingprep for enhanced US stock fundamentals

# Cache Configuration
CACHE_TTL_HOURS=1
FUNDAMENTAL_CACHE_TTL_HOURS=24

# Stage Weights (must sum to 1.0)
STAGE1_WEIGHT=0.6
STAGE2_WEIGHT=0.2
STAGE3_WEIGHT=0.2
