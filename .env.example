# LLM 配置（支持 OpenAI / DeepSeek / Qwen 等 OpenAI 兼容 API）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o

# 数据源配置
DEFAULT_PERIOD=2y
DEFAULT_INTERVAL=1d
FMP_API_KEY=  # 可选：financialmodelingprep 用于美股财报增强

# 缓存配置
CACHE_TTL_HOURS=1
FUNDAMENTAL_CACHE_TTL_HOURS=24

# 权重配置（可调）
STAGE1_WEIGHT=0.6
STAGE2_WEIGHT=0.2
STAGE3_WEIGHT=0.2
